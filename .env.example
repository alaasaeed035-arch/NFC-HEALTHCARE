# ==================== DATABASE ====================
DB_URL=your_database_link_here

# ==================== APPLICATION ====================
PORT=3000
JWT_SECRET=your_jwt_secret_here
# Public URL used in verification emails — set this to your deployed domain
# e.g. https://your-app.onrender.com  (no trailing slash)
BASE_URL=http://localhost:3000

# ==================== DDI SERVICE (main.py — port 8000) ====================
# Get your key from https://console.groq.com/keys
DDI_GROQ_API_KEY=your_ddi_groq_api_key_here
DDI_SERVICE_URL=http://localhost:8000

# ==================== CHATBOT SERVICE (chatbot.py — port 8001) ====================
CHATBOT_GROQ_API_KEY=your_chatbot_groq_api_key_here
CHATBOT_GROQ_MODEL=llama-3.3-70b-versatile
CHATBOT_SERVICE_URL=http://localhost:8001

# ==================== RAG / COLLECTIONS ====================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
KB_COLLECTION=kb_documents
PATIENT_COLLECTION=medicalrecords
CHAT_COLLECTION=patient_chat_logs

# ==================== EMAIL ====================
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=

# ==================== CLOUDINARY ====================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
